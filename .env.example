# Copy this file to .env and fill in the values.
# Never commit .env.

# Anthropic API key for Claude Sonnet 4.5.
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# GitHub classic Personal Access Token for the Founder agent.
# Create at: GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# Grant: repo and delete_repo.
# Intended demo role: admin-level access on CODE_REPO, read access on HANDBOOK_REPO.
GITHUB_PAT_FOUNDER=

# GitHub classic Personal Access Token for the SDE agent.
# Create at: GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# Grant: repo for the code repo work, and public_repo for read access to the handbook repo.
# Intended demo role: read/write on CODE_REPO, read-only on HANDBOOK_REPO.
GITHUB_PAT_SDE=

# GitHub classic Personal Access Token for the HR agent.
# Create at: GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# Grant: public_repo for read access to the code repo, and repo for write access to the handbook repo.
# Intended demo role: read-only on CODE_REPO, read/write on HANDBOOK_REPO.
GITHUB_PAT_HR=

# GitHub classic Personal Access Token for the Intern agent.
# Create at: GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# Grant: public_repo only.
# Intended demo role: public read-only access.
GITHUB_PAT_INTERN=

# Shared code repo for Founder, SDE, HR, and Intern to inspect.
# Format: owner/repo
CODE_REPO=

# Separate handbook repo where HR can post summaries.
# Format: owner/repo
HANDBOOK_REPO=
